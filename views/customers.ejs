<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BCIT Parkly</title>
</head>
<body>
    <h1>Customers</h1>
    <ul>
        <% customers.forEach(customer => { %>
            <li><%= customer.customer_name %> - <%= customer.email %> - <%= customer.phone %> - <%= customer.customer_type %></li>
        <% }) %>
    </ul>
</body>
</html>