<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login</title>
    <link rel="stylesheet" type="text/css" href="/css/main.css" />
    <link rel="stylesheet" type="text/css" href="/css/login.css" />
    <script
      src="https://kit.fontawesome.com/39589cb536.js"
      crossorigin="anonymous"
    ></script>
  </head>
  <body>
    <!-- THE TOP HEADER AREA -->
    <header>
      <a href="/"><img src="/assets/bcit-logo.png" alt="BCIT Logo" /></a>
      <div class="header-titles">
        <h2>Parkly</h2>
        <h6>Downtown Campus</h6>
      </div>
      <div class="header-tabs">
        <a href="/">Find Parking</a>
        <a href="/info/permits">Permits & Rates</a>
        <a href="/reserve/reservations">My Reservations</a>
        <a href="/info/help">Help & Support</a>
      </div>
    <% if (locals.user === null) { %>
    <a role="button" href="/users/login" class="sign-in-btn">
    <i class="fa-solid fa-user"></i>
    Sign In
    </a>
    <% } else { %>
    <a role="button" href="/users/logout" class="sign-in-btn">
    <i class="fa-solid fa-user"></i>
    Sign Out
    </a>
    <% } %>
    </header>

    <!--Breadcrumb bar under the header bar-->
    <section class="breadcrumb-bar">
      <div class="subheading">
        <a href="/">Home</a>
        <span class="seperator">›</span>
        <span class="current-pg">SignUp</span>
      </div>
    </section>

    <div class="confirmation-container">
      <div class="confirmation-card">

        <div class="confirmation-icon">
          <img src="/assets/Eo_circle_green_checkmark.svg.png" alt="Registration successful">
        </div>

        <h1 class="confirmation-title">Registration Complete!</h1>
        <p class="confirmation-subtitle">Your Parkly account has been successfully created.</p>

        <div class="confirmation-email-wrapper">
          <p class="confirmation-email-label">Registered with</p>
          <span class="confirmation-email-pill">
            <i class="fa-solid fa-envelope"></i>
            <%= locals.confirmedEmail %>
          </span>
        </div>

        <hr class="confirmation-divider">

        <div class="next-steps">
          <p class="next-steps-title">What's next?</p>
          <ul class="next-steps-list">
            <li><span class="step-badge">1</span> Log in to your new account using the button below.</li>
            <li><span class="step-badge">2</span> Browse available parking lots and reserve a spot.</li>
            <li><span class="step-badge">3</span> Manage your reservations anytime from your dashboard.</li>
          </ul>
        </div>

        <a href="/users/login" class="confirmation-cta">Log In to Parkly</a>

        <p class="confirmation-help">
          Need help? <a href="/info/help">Visit our Help &amp; Support page</a>
        </p>

      </div>
    </div>


    <footer>
      <div class="footer-container">
        <div class="footer-col">
          <div class="footer-logo">
            <img src="/assets/bcit-logo.png" alt="BCIT Logo" />
          </div>
          <p>
            3700 Willingdon Ave.
            <br />
            Burnaby, British Columbia
            <br />
            Canada V5G 3H2
          </p>
          <p>
            604-434-5734
            <br />
            1-866-434-1610
          </p>
        </div>
        <div class="footer-col">
          <h4>QUICK LINKS</h4>
          <ul>
            <li><a href="#">Visit</a></li>
            <li><a href="#">Apply Now</a></li>
            <li><a href="#">Give</a></li>
            <li><a href="#">News</a></li>
            <li><a href="#">Events</a></li>
            <li><a href="#">Careers</a></li>
          </ul>
        </div>
        <div class="footer-col">
          <h4>BCIT CAMPUSES</h4>
          <ul>
            <li><a href="#">Burnaby Campus</a></li>
            <li><a href="#">Downtown Campus</a></li>
            <li><a href="#">Marine Campus</a></li>
            <li><a href="#">Aerospace Technology Campus</a></li>
            <li><a href="#">Annacis Island Campus</a></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">
        <div class="footer-bottom-links">
          <a href="#">Copyright</a>
          <a href="#">Privacy</a>
          <a href="#">Terms of Use</a>
          <a href="#">Accessibility</a>
        </div>
      </div>
    </footer>
  </body>
</html>
